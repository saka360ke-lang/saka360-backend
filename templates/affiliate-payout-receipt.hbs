<table width="100%" cellpadding="0" cellspacing="0" style="font-family:Arial,sans-serif; background:#f7f7f8; padding:24px;">
  <tr><td align="center">
    <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:12px; overflow:hidden;">
      <tr>
        <td style="padding:20px 24px; background:#111827; color:#fff; font-size:18px; font-weight:700;">
          Saka360 — Affiliate Payout Receipt
        </td>
      </tr>
      <tr>
        <td style="padding:24px; color:#111827; font-size:14px; line-height:1.6;">
          <p>Hi {{partner_name}},</p>
          <p>Your affiliate payout is complete.</p>

          <table width="100%" style="border-collapse:collapse; margin:16px 0;">
            <tr><td style="padding:8px; border:1px solid #e5e7eb;">Payout #</td><td style="padding:8px; border:1px solid #e5e7eb;">{{payout_id}}</td></tr>
            <tr><td style="padding:8px; border:1px solid #e5e7eb;">Period</td><td style="padding:8px; border:1px solid #e5e7eb;">{{period_start}} – {{period_end}}</td></tr>
            <tr><td style="padding:8px; border:1px solid #e5e7eb;">Amount</td><td style="padding:8px; border:1px solid #e5e7eb;">{{formatCents amount_cents currency}}</td></tr>
            <tr><td style="padding:8px; border:1px solid #e5e7eb;">Method</td><td style="padding:8px; border:1px solid #e5e7eb;">{{payment_method}}</td></tr>
            {{#if reference}}<tr><td style="padding:8px; border:1px solid #e5e7eb;">Reference</td><td style="padding:8px; border:1px solid #e5e7eb;">{{reference}}</td></tr>{{/if}}
          </table>

          <p>Thank you for partnering with Saka360.</p>
          <p>— Affiliates Team</p>
        </td>
      </tr>
      <tr>
        <td style="padding:16px 24px; font-size:12px; color:#6b7280; background:#f3f4f6;">
          You’re receiving this because you’re enrolled in the Saka360 affiliate program.
        </td>
      </tr>
    </table>
  </td></tr>
</table>
