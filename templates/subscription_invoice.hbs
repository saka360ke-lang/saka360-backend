<!DOCTYPE html>
<html>
  <body style="font-family:Arial,Helvetica,sans-serif; line-height:1.6; color:#222;">
    <h2>Your Subscription Invoice</h2>
    <p><strong>Plan:</strong> {{plan_name}} ({{plan_code}})</p>
    <p><strong>Period:</strong> {{period_start}} → {{period_end}}</p>
