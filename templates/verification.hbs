<table width="100%" cellpadding="0" cellspacing="0" style="font-family:Arial,sans-serif; background:#f7f7f8; padding:24px;">
  <tr><td align="center">
    <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:12px; overflow:hidden;">
      <tr>
        <td style="padding:20px 24px; background:#111827; color:#fff; font-size:18px; font-weight:700;">
          Saka360 — Verify your account
        </td>
      </tr>
      <tr>
        <td style="padding:24px; color:#111827; font-size:14px; line-height:1.6;">
          <p>Hi {{user_name}},</p>
          <p>Welcome to Saka360! Please confirm your email to secure your account and start managing your vehicle records.</p>
          <p style="margin:24px 0;">
            <a href="{{verification_link}}" style="display:inline-block; background:#0ea5e9; color:#fff; padding:12px 18px; border-radius:8px; text-decoration:none; font-weight:700;">
              Verify Email
            </a>
          </p>
          <p>If the button doesn’t work, copy and paste this URL into your browser:</p>
          <p style="word-break:break-all; color:#2563eb;">{{verification_link}}</p>
          <p>Thanks,<br/>Saka360 Team</p>
        </td>
      </tr>
      <tr>
        <td style="padding:16px 24px; font-size:12px; color:#6b7280; background:#f3f4f6;">
          You’re receiving this email because you created a Saka360 account.
        </td>
      </tr>
    </table>
  </td></tr>
</table>
